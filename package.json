{
  "name": "kopienas-pieprasijumi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3020",
    "build": "next build",
    "start": "next start -p 3020",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "check": "eslint . && tsc --noEmit && vitest run && next build"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "libphonenumber-js": "1.13.9",
    "next": "16.1.6",
    "postgres": "3.4.9",
    "qrcode": "1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/qrcode": "1.5.5",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
