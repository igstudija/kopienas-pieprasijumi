NODE_ENV=development
APP_URL=http://localhost:3020
DATABASE_URL=postgres://community:community@localhost:5433/community

# First-run password chosen by the instance owner. Required in production.
SETUP_SECRET=choose-a-long-unique-installation-password

# Public GitHub template URL used by /help/install to build the Deploy button.
NEXT_PUBLIC_TEMPLATE_REPOSITORY_URL=https://github.com/igstudija/kopienas-pieprasijumi

# Optional explicit overrides. On Vercel + Supabase these are derived from
# SUPABASE_SECRET_KEY / the database credential when left empty.
# Generate secrets with: openssl rand -base64 32
APP_SECRET=replace-with-at-least-32-random-characters
PHONE_LOOKUP_SECRET=replace-with-a-different-random-secret
# Lokāli atstāj tukšu, lai izmantotu tikai izstrādei paredzēto atslēgu.
# Production vidē vērtība tiek deterministiski iegūta no instances credentials.
DATA_ENCRYPTION_KEY=

WHATSAPP_BUSINESS_NUMBER=+37120000001

# Production WhatsApp Cloud API settings
WHATSAPP_GRAPH_VERSION=v24.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-webhook-token

# First local owner created by pnpm db:seed
SEED_OWNER_PHONE=+37120000000
SEED_OWNER_FIRST_NAME=Artis
SEED_OWNER_LAST_NAME=Codars
SEED_OWNER_COMPANY=Codars
# Lokāli tukšai vērtībai izmanto development-admin; production seed parole ir obligāta.
SEED_OWNER_PASSWORD=

# Legacy/manual seed configuration. The web setup wizard generates and stores
# the production instance identity and federation keys automatically.
INSTANCE_ID=00000000-0000-4000-8000-000000000001
INSTANCE_NAME=Uzņēmēju kopiena
FEDERATION_KEY_ID=primary-2026
FEDERATION_PUBLIC_KEY=
FEDERATION_PRIVATE_KEY=
